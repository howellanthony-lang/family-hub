# ═══════════════════════════════════════════════════════
#  Family Hub Configuration — copy to .env and edit
#  NEVER commit .env to git
# ═══════════════════════════════════════════════════════

# API port (default 3001)
PORT=3001

# API keys for remote access (comma separated, leave blank for local-only)
# Generate one with: node -e "require('crypto').randomBytes(32).toString('hex').then?console.log:console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEYS=

# ── Your iCloud public calendar ──────────────────────────
# In iPhone Calendar app: right-click calendar → Share → Copy Link
WEBCAL_URLS=webcal://p114-caldav.icloud.com/published/2/YOUR_PUBLIC_CALENDAR_LINK

# ── Google Calendar ───────────────────────────────────────
# console.cloud.google.com → Calendar API → OAuth → TV/Limited Input device
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=primary

# ── Apple CalDAV (two-way sync) ──────────────────────────
# appleid.apple.com → App-Specific Passwords → + → "Family Hub"
APPLE_USERNAME=
APPLE_PASSWORD=
# Run: curl http://localhost:3001/api/integrations/apple/calendars → paste URL here
APPLE_CALENDAR_URL=

# ── Weather ───────────────────────────────────────────────
WEATHER_LOCATION=Wakefield, UK

# ── Photo frame ───────────────────────────────────────────
# Local folder scanned by the photo frame. Put .jpg/.png/.webp files here.
PHOTO_DIR=apps/api/data/photos

# ── Backups / resilience ─────────────────────────────────────
BACKUP_DIR=apps/api/data/backups
MAX_BACKUPS=20

# ── Home Assistant optional smart-home bridge ────────────────
# Create a long-lived token in Home Assistant profile settings.
HOME_ASSISTANT_URL=http://127.0.0.1:8123
HOME_ASSISTANT_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJkNDEwOWMyZDg5YTE0MjQ5OGZkMGI1MjE4YzQ5NmNlOSIsImlhdCI6MTc3ODgzNDIxMywiZXhwIjoyMDk0MTk0MjEzfQ.LKgmUzNXi3Y7imwQIZhoT8Ms_YnYLNCwraDKbvCXb6I
SMART_HOME_ENABLED=true

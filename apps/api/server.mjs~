await app.listen
const HOME_ASSISTANT_URL = process.env.HOME_ASSISTANT_URL || '';
const HOME_ASSISTANT_TOKEN = process.env.HOME_ASSISTANT_TOKEN || '';

function haConfigured() {
  return Boolean(HOME_ASSISTANT_URL && HOME_ASSISTANT_TOKEN);
}

async function haRequest(endpoint, options = {}) {
  const response = await fetch(`${HOME_ASSISTANT_URL}${endpoint}`, {
    ...options,
    headers: {
      Authorization: `Bearer ${HOME_ASSISTANT_TOKEN}`,
      'Content-Type': 'application/json',
      ...(options.headers || {})
    }
  });

  if (!response.ok) {
    throw new Error(`Home Assistant request failed: ${response.status}`);
  }

  return response.json();
}

function filterDomain(entities, domain) {
  return entities.filter(entity =>
    entity.entity_id.startsWith(`${domain}.`)
  );
}

app.get('/api/home-assistant/status', async () => {
  if (!haConfigured()) {
    return {
      ok: false,
      connected: false,
      error: 'Home Assistant not configured'
    };
  }

  try {
    const config = await haRequest('/api/config');

    return {
      ok: true,
      connected: true,
      location: config.location_name,
      unitSystem: config.unit_system,
      version: config.version
    };
  } catch (error) {
    return {
      ok: false,
      connected: false,
      error: error.message
    };
  }
});

app.get('/api/home-assistant/entities', async () => {
  const entities = await haRequest('/api/states');

  return {
    ok: true,
    count: entities.length,
    entities
  };
});

app.get('/api/home-assistant/lights', async () => {
  const entities = await haRequest('/api/states');

  return {
    ok: true,
    lights: filterDomain(entities, 'light')
  };
});

app.get('/api/home-assistant/scenes', async () => {
  const entities = await haRequest('/api/states');

  return {
    ok: true,
    scenes: filterDomain(entities, 'scene')
  };
});

app.get('/api/home-assistant/calendars', async () => {
  const entities = await haRequest('/api/states');

  return {
    ok: true,
    calendars: filterDomain(entities, 'calendar')
  };
});

app.post('/api/home-assistant/service', async (request) => {
  const { domain, service, data } = request.body;

  const result = await haRequest(
    `/api/services/${domain}/${service}`,
    {
      method: 'POST',
      body: JSON.stringify(data || {})
    }
  );

  return {
    ok: true,
    result
  };
});

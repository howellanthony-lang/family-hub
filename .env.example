# Family Hub Configuration — copy to .env and edit
# NEVER commit .env to git

PORT=3001
API_KEYS=

# Public iCloud/webcal feeds, comma-separated
WEBCAL_URLS=

# Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=primary

# Apple CalDAV two-way sync
APPLE_USERNAME=
APPLE_PASSWORD=
APPLE_CALENDAR_URL=
